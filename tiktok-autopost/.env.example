STABILITY_API_KEY=sk-...

# TikTok Developer (https://developers.tiktok.com/)
TIKTOK_CLIENT_KEY=aw...
TIKTOK_CLIENT_SECRET=...
TIKTOK_REDIRECT_URI=http://localhost:8080/callback

# 投稿のプライバシー設定
# SELF_ONLY / MUTUAL_FOLLOW_FRIENDS / FOLLOWER_OF_CREATOR / PUBLIC_TO_EVERYONE
